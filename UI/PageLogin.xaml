<Window x:Class="He_Thong_Diem_Danh_Qr.UI.PageLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập"
        Height="650"
        Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent">

    <!-- 🔥 Đặt Style trong Resources -->
    <Window.Resources>
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="20"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                Background="White">
                            <ScrollViewer Margin="10"
                                          x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedPasswordBox" TargetType="PasswordBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border CornerRadius="20"
                                BorderBrush="#CCCCCC"
                                BorderThickness="1"
                                Background="White">
                            <ScrollViewer Margin="10"
                                          x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Image Source="/UI/3dca3db9-78c2-4f40-9533-e816f6def63e.jpg"
               Stretch="UniformToFill"
               Opacity="0.8">
            <Image.Effect>
                <BlurEffect Radius="7"/>
            </Image.Effect>
        </Image>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="412" 
                    Height="549">

            <TextBlock Text="Hello"
                       FontFamily="Arial Rounded MT Bold"
                       FontSize="48"
                       Margin="0,0,0,20"
                       TextAlignment="Center"/>

            <TextBlock Text="Sign in to your account"
                       TextAlignment="Center"
                       FontSize="18"
                       Margin="0,0,0,100" FontFamily="Arial Rounded MT Bold"/>
            <TextBlock Text="Username"
                       Foreground="Black"
                       FontSize="14"
                       FontWeight="SemiBold" Height="24" Width="288"/>

            <TextBox x:Name="txtUsername"
                     Width="300"
                     Height="45"
                     Style="{StaticResource RoundedTextBox}"
                     FontSize="16" 
                     Margin="0,0,0,20"/>

            <TextBlock
                       Text="Password"
                       Foreground="Black"
                       Margin="15,0,0,5"
                       FontSize="14"
                       FontWeight="SemiBold" Height="15" Width="305"/>

            <PasswordBox x:Name="txtPassword"
                         Width="300"
                         Height="45"
                         Style="{StaticResource RoundedPasswordBox}"
                         FontSize="16"
                         Margin="0,0,0,25"/>

            <Button x:Name="btnLogin"
                    Content="Đăng nhập"
                    Width="204"
                    Height="45"
                    Background="#4CAF50"
                    Foreground="White"
                    FontSize="16"
                    FontWeight="Bold"
                    BorderBrush="Transparent"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="20"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>